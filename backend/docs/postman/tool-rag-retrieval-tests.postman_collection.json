{
  "info": {
    "_postman_id": "b4d8b8b7-75f1-4d27-9b83-toolragtests",
    "name": "tool-rag Retrieval Tests",
    "description": "Retrieval debug tests for the tool-rag Spring Web API. Run this collection after the app and pgvector are running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('HTTP 200', function () {",
          "  pm.response.to.have.status(200);",
          "});",
          "",
          "const json = pm.response.json();",
          "const results = json.results || [];",
          "const expectedSource = pm.variables.get('expected_source_file');",
          "const expectedBlockType = pm.variables.get('expected_block_type');",
          "const expectedPageMin = Number(pm.variables.get('expected_page_min') || 0);",
          "const expectedPageMax = Number(pm.variables.get('expected_page_max') || 0);",
          "const caseId = pm.variables.get('case_id');",
          "",
          "pm.test(`[${caseId}] response has resultCount`, function () {",
          "  pm.expect(json).to.have.property('resultCount');",
          "});",
          "",
          "if (expectedSource !== 'none') {",
          "  pm.test(`[${caseId}] has retrieval results`, function () {",
          "    pm.expect(results.length).to.be.greaterThan(0);",
          "  });",
          "",
          "  const expectedSources = expectedSource.split(',').map(s => s.trim()).filter(Boolean);",
          "  const sourceHit = results.some(r => expectedSources.includes(r.sourceFile));",
          "  pm.test(`[${caseId}] hits expected source file`, function () {",
          "    pm.expect(sourceHit, `expected one of ${expectedSources.join(', ')}`).to.equal(true);",
          "  });",
          "",
          "  if (expectedBlockType && expectedBlockType !== 'none') {",
          "    const blockHit = results.some(r => r.blockType === expectedBlockType);",
          "    pm.test(`[${caseId}] hits expected block type`, function () {",
          "      pm.expect(blockHit, `expected block_type ${expectedBlockType}`).to.equal(true);",
          "    });",
          "  }",
          "",
          "  if (expectedPageMin > 0 && expectedPageMax > 0) {",
          "    const pageHit = results.some(r => {",
          "      const start = Number(r.pageStart || 0);",
          "      const end = Number(r.pageEnd || start);",
          "      return end >= expectedPageMin && start <= expectedPageMax;",
          "    });",
          "    pm.test(`[${caseId}] overlaps expected page range`, function () {",
          "      pm.expect(pageHit, `expected overlap with pages ${expectedPageMin}-${expectedPageMax}`).to.equal(true);",
          "    });",
          "  }",
          "} else {",
          "  pm.test(`[${caseId}] out-of-domain diagnostic only`, function () {",
          "    pm.expect(json).to.have.property('results');",
          "  });",
          "}"
        ]
      }
    }
  ],
