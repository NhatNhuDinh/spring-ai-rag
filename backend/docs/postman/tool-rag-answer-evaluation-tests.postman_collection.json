{
  "info": {
    "_postman_id": "ac30ca7d-66aa-4319-9e5c-2ebc6d30a5f2",
    "name": "tool-rag Answer Evaluation And Guardrails Tests",
    "description": "Postman collection for running answer-level evaluation and guardrail checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('application is UP', function () {",
              "  pm.expect(pm.response.json().status).to.eql('UP');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      },
      "response": []
    },
    {
      "name": "02 - List Answer Test Cases",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('default test cases are returned', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.be.an('array').and.not.empty;",
              "  pm.expect(body[0]).to.have.property('question');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/evaluation/answer-tests",
          "host": ["{{baseUrl}}"],
          "path": ["api", "evaluation", "answer-tests"]
        }
      },
      "response": []
    },
    {
      "name": "03 - Run Default Answer Evaluation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('evaluation summary is returned', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.total).to.be.a('number');",
              "  pm.expect(body.results).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/evaluation/answer-tests/run",
          "host": ["{{baseUrl}}"],
          "path": ["api", "evaluation", "answer-tests", "run"]
        }
      },
      "response": []
    },
    {
      "name": "04 - Run Custom Single Answer Test",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('custom evaluation result is returned', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.total).to.eql(1);",
              "  pm.expect(body.results[0]).to.have.property('citationValidation');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"id\": \"custom_surplus_value\",\n    \"question\": \"Giá trị thặng dư là gì?\",\n    \"expectedSourceFile\": \"triet_2.pdf\",\n    \"expectedChapter\": \"3\",\n    \"mustMention\": [\"giá trị thặng dư\"],\n    \"mustNotMention\": [],\n    \"mustHaveCitation\": true,\n    \"shouldRefuse\": false,\n    \"refusalMustMention\": []\n  }\n]"
        },
        "url": {
          "raw": "{{baseUrl}}/api/evaluation/answer-tests/run-custom",
          "host": ["{{baseUrl}}"],
          "path": ["api", "evaluation", "answer-tests", "run-custom"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
