          {"key": "Accept", "value": "text/event-stream"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [{\"type\": \"text\", \"text\": \"Giá trá» tháº·ng dÆ° là gì?\"}]\n    }\n  ],\n  \"threadId\": \"thread-1\"\n}"
        },
        "url": "{{baseUrl}}/api/chat/ui-stream"
      }
    }
  ]
}
