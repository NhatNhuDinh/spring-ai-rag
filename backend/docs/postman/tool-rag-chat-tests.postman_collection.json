    {
      "name": "06 - Retrieval Context Debug For Same Question",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('context contains seed chunks', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.resultCount).to.be.greaterThan(0);",
              "  pm.expect(body.results.some(r => r.retrievalRole === 'seed')).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"Tư bản bất biến và tư bản khả biến khác nhau như thế nào?\",\n  \"topK\": 4,\n  \"similarityThreshold\": 0.0\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/retrieval/context",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "retrieval",
            "context"
          ]
        }
