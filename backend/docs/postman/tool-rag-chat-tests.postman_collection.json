    {
      "name": "07 - Packaged Context With Citations Debug",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('packaged context has citation labels', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.sourceCount).to.be.greaterThan(0);",
              "  pm.expect(body.context).to.include('RAG_CONTEXT');",
              "  pm.expect(body.context).to.include('[S1]');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
