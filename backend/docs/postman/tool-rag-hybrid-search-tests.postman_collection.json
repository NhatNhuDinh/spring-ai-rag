    {
      "name": "04 - Hybrid Search",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('hybrid search exposes hybrid metadata', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.resultCount).to.be.greaterThan(0);",
              "  pm.expect(body.results[0].retrievalMode).to.eql('hybrid');",
              "  pm.expect(body.results[0].matchedBy).to.be.a('string').and.not.empty;",
              "  pm.expect(body.results[0].hybridScore).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
