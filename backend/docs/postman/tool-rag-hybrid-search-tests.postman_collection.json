    {
      "name": "05 - Parent Context Uses Hybrid Seeds",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('context includes seed and hybrid metadata', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.resultCount).to.be.greaterThan(0);",
              "  pm.expect(body.results.some(r => r.retrievalRole === 'seed')).to.eql(true);",
              "  pm.expect(body.results.some(r => r.retrievalMode === 'hybrid')).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
