          "raw": "{\n  \"query\": \"{{testQuery}}\",\n  \"topK\": {{topK}},\n  \"similarityThreshold\": {{similarityThreshold}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/retrieval/context",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "retrieval",
            "context"
          ]
        }
      },
      "response": []
    },
    {
      "name": "06 - Packaged Context Shows Hybrid Metadata",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('packaged context includes hybrid fields', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.sourceCount).to.be.greaterThan(0);",
              "  pm.expect(body.context).to.include('[S1]');",
              "  pm.expect(body.context).to.include('Retrieval mode: hybrid');",
              "  pm.expect(body.context).to.include('Matched by:');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
