          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('raw vector search returns results', function () {",
              "  pm.expect(pm.response.json().resultCount).to.be.greaterThan(0);",
              "});"
