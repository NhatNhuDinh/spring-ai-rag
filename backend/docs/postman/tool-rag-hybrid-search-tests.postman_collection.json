          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('transformed search exposes retrievalQuery', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.resultCount).to.be.greaterThan(0);",
              "  pm.expect(body.results[0].retrievalQuery).to.be.a('string').and.not.empty;",
              "});"
