    {
      "name": "06 - Chat Uses Transformed RAG Pipeline",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('chat returns answer and conversationId', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.conversationId).to.be.a('string').and.not.empty;",
              "  pm.expect(body.answer).to.be.a('string').and.not.empty;",
              "  pm.collectionVariables.set('conversationId', body.conversationId);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
