            "api",
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 - Query Transform - Everyday Economics Query",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('query is expanded and routed to political economy chapter 3', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.retrievalQueries.length).to.be.greaterThan(1);",
              "  pm.expect(body.sourceFile).to.eql('triet_2.pdf');",
              "  pm.expect(body.chapterNumber).to.eql('3');",
              "  const normalizedQueries = body.retrievalQueries.join(' ').normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').replace(/đ/g, 'd').replace(/Đ/g, 'D').toLowerCase();",
              "  pm.expect(normalizedQueries).to.include('gia tri thang du');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"{{everydayEconomicsQuery}}\",\n  \"topK\": {{topK}},\n  \"similarityThreshold\": {{similarityThreshold}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/retrieval/query-transform",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "retrieval",
            "query-transform"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 - Query Transform - Basic Philosophy Query",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('query is expanded and routed to philosophy chapter 1', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.retrievalQueries.length).to.be.greaterThan(1);",
              "  pm.expect(body.sourceFile).to.eql('triet_1.pdf');",
              "  pm.expect(body.chapterNumber).to.eql('1');",
              "  const normalizedQueries = body.retrievalQueries.join(' ').normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').replace(/đ/g, 'd').replace(/Đ/g, 'D').toLowerCase();",
              "  pm.expect(normalizedQueries).to.include('van de co ban cua triet hoc');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
