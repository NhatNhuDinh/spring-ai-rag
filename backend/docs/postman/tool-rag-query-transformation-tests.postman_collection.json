    {
      "name": "05 - Packaged Context Uses Transformed Retrieval",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('packaged context includes citation and retrieval query', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.sourceCount).to.be.greaterThan(0);",
              "  pm.expect(body.context).to.include('[S1]');",
