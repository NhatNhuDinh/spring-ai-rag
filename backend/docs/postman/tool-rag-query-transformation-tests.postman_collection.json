    {
      "name": "04 - Transformed Retrieval",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('transformed retrieval exposes retrieval query metadata', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.resultCount).to.be.greaterThan(0);",
              "  pm.expect(body.results[0].queryTransformed).to.eql(true);",
              "  pm.expect(body.results[0].retrievalQuery).to.be.a('string').and.not.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
